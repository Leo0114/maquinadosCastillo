---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import HeroSection from "@/components/home/HeroSection.astro";
import StatsBand from "@/components/shared/StatsBand.astro";
import ServiciosGrid from "@/components/home/ServiciosGrid.astro";
import CTABanner from "@/components/shared/CTABanner.astro";
import GallerySection from "@/components/shared/GallerySection.astro";
import VideoSection from "@/components/home/VideoSection.astro";
import SectionHeader from "@/components/shared/SectionHeader.astro";
import ScrollReveal from "@/components/shared/ScrollReveal.tsx";

import previewImg1 from "@/assets/images/metal/metal1.avif";
import previewImg2 from "@/assets/images/metal/metal5.avif";
import previewImg3 from "@/assets/images/metal/metal20.avif";
import previewImg4 from "@/assets/images/metal/metal25.avif";

const stats = [
  { value: "30", label: "Años de experiencia", suffix: "+" },
  { value: "12", label: "Técnicos especializados" },
  { value: "5", label: "Centros CNC" },
  { value: "3", label: "Scanners 3D" },
];

// Why us points
const whyUs = [
  { icon: "⚡", text: "Respuesta ágil para requerimientos urgentes" },
  { icon: "🔗", text: "Integración: diseño + maquinado + ajuste + metrología 3D" },
  { icon: "📦", text: "Flexibilidad en volúmenes (prototipos a series cortas)" },
  { icon: "🛠️", text: "Solución a piezas complejas o críticas" },
  { icon: "🏗️", text: "Fabricación, reparación y diseño de moldes y troqueles" },
  { icon: "🔬", text: "Escaneo 3D, metrología e ingeniería inversa" },
];
---

<Layout
  title="Maquinados Castillo — Precisión, Experiencia y Calidad desde 1996"
  description="Empresa mexicana con más de 30 años en maquinado de precisión, moldes, matrices y herramentales. Escobedo, Nuevo León."
>
  <!-- 1. Hero Slider -->
  <HeroSection />

  <!-- 2. Stats Band -->
  <StatsBand stats={stats} />

  <!-- 3. Servicios Destacados -->
  <ServiciosGrid />

  <!-- 4. ¿Por qué Maquinados Castillo? -->
  <section class="section-py bg-panel">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <ScrollReveal client:visible direction="right">
          <div>
            <SectionHeader
              eyebrow="¿Por qué elegirnos?"
              title="Razones para trabajar con nosotros"
              subtitle="Más de 30 años siendo el socio de manufactura de precisión que las industrias más exigentes confían."
              align="left"
            />
            <ul class="mt-8 space-y-4">
              {whyUs.map(({ icon, text }) => (
                <li class="flex items-center gap-4">
                  <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-xl">
                    {icon}
                  </span>
                  <span class="text-ink-muted text-sm leading-relaxed">{text}</span>
                </li>
              ))}
            </ul>
            <div class="mt-9 flex flex-wrap gap-4">
              <a
                href="/acerca-de"
                class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-primary text-white text-xs font-bold uppercase tracking-widest hover:bg-primary-dark transition-all duration-300 hover:-translate-y-0.5 shadow-lg shadow-primary/20"
              >
                Conocer más
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
              <a
                href="/contacto"
                class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border-2 border-primary text-primary text-xs font-bold uppercase tracking-widest hover:bg-primary hover:text-white transition-all duration-300"
              >
                Contactar
              </a>
            </div>
          </div>
        </ScrollReveal>

        <!-- Gallery grid preview -->
        <ScrollReveal client:visible direction="left" delay={0.15}>
          <div class="grid grid-cols-2 gap-3">
            {[previewImg1, previewImg2, previewImg3, previewImg4].map((img, i) => (
              <div class:list={[
                "relative overflow-hidden rounded-2xl",
                i === 0 ? "col-span-2 h-48" : "h-36",
              ]}>
                <Image
                  src={img}
                  alt={`Trabajo maquinado ${i + 1}`}
                  width={i === 0 ? 800 : 400}
                  height={i === 0 ? 300 : 220}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- 5. CTA Banner -->
  <CTABanner
    eyebrow="Proyectos urgentes"
    title="¿La línea de producción no puede parar?"
    subtitle="Contamos con capacidad de respuesta ágil para situaciones de emergencia industrial. Contáctenos ahora."
    buttonText="Contáctanos ahora"
    buttonLink="/contacto"
  />

  <!-- 6. Gallery -->
  <section class="section-py bg-canvas">
    <div class="container-custom">
      <ScrollReveal client:visible direction="up" className="mb-12">
        <SectionHeader
          eyebrow="Galería"
          title="Nuestras piezas y trabajos"
          subtitle="Una selección de proyectos y trabajos que reflejan la precisión y calidad de Maquinados Castillo."
        />
      </ScrollReveal>
      <ScrollReveal client:visible direction="up" delay={0.15}>
        <GallerySection folder="metal" columns={3} limit={9} />
      </ScrollReveal>
    </div>
  </section>

  <!-- 7. Video Section -->
  <VideoSection />

  <!-- 8. Final CTA -->
  <CTABanner
    title="Maquinados Castillo — Precisión desde 1996"
    subtitle="Parte del ecosistema de manufactura avanzada de Nuevo León. Intégrenos a su cadena de suministro."
    buttonText="Solicitar información"
    buttonLink="/contacto"
    variant="primary"
  />
</Layout>
