---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/shared/PageHero.astro";
import ContactoSection from "@/components/contacto/ContactoSection.astro";
import CTABanner from "@/components/shared/CTABanner.astro";
import ScrollReveal from "@/components/shared/ScrollReveal.tsx";

import heroImg from "@/assets/images/metal/metal27.avif";
---

<Layout
  title="Contacto — Maquinados Castillo"
  description="Contáctenos para requerimientos de maquinado, moldes, troqueles e ingeniería de precisión. Escobedo, Nuevo León. Tel: 81 8479 4210."
>
  <!-- 1. Page Hero -->
  <PageHero
    eyebrow="Contáctenos"
    title="Listos para su proyecto"
    subtitle="Listos para formar parte de sus requerimientos de maquinados, troqueles, matrices e ingenierías."
    imageSrc={heroImg.src}
  />

  <!-- 2. Contact Section -->
  <ContactoSection />

  <!-- 3. Cluster Info -->
  <section class="section-py bg-panel">
    <div class="container-custom">
      <ScrollReveal client:visible direction="up">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full border border-primary/30 bg-primary/5 mb-6">
            <span class="w-2 h-2 rounded-full bg-primary animate-pulse" />
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">
              Cluster de Herramentales de Nuevo León
            </span>
          </div>
          <h2 class="font-display font-bold text-2xl sm:text-3xl text-ink mb-4">
            Parte del ecosistema de manufactura avanzada de Nuevo León
          </h2>
          <p class="text-ink-muted leading-relaxed">
            Maquinados Castillo está integrada al Cluster de Herramentales de Nuevo León, una red de empresas de alto desempeño que impulsan la competitividad de la industria manufacturera regional. Esta integración nos permite acceder a tecnología de punta, colaboraciones estratégicas y programas de desarrollo empresarial que benefician directamente a nuestros clientes.
          </p>
        </div>
      </ScrollReveal>

      <!-- Map placeholder / Location visual -->
      <ScrollReveal client:visible direction="up" delay={0.15} className="mt-12">
        <div class="relative overflow-hidden rounded-3xl h-64 bg-secondary border border-line">
          <div class="absolute inset-0 flex items-center justify-center flex-col gap-4">
            <div class="w-16 h-16 rounded-full bg-primary/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div class="text-center">
              <p class="font-display font-bold text-white text-lg">Maquinados Castillo</p>
              <p class="text-white/60 text-sm">Escobedo, Nuevo León, México</p>
            </div>
            <a
              href="https://maps.google.com/?q=Escobedo,+Nuevo+León+México"
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-2.5 rounded-full border border-white/20 text-white text-xs font-semibold uppercase tracking-widest hover:bg-white/10 transition-colors"
            >
              Ver en Google Maps
            </a>
          </div>
          <!-- Grid decoration -->
          <div
            class="absolute inset-0 opacity-5 pointer-events-none"
            style="background-image: repeating-linear-gradient(0deg, white 0, white 1px, transparent 1px, transparent 40px), repeating-linear-gradient(90deg, white 0, white 1px, transparent 1px, transparent 40px);"
          />
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- 4. Final CTA -->
  <CTABanner
    title="¿Tiene un requerimiento urgente?"
    subtitle="Cuando la línea de producción no puede parar, contáctenos por WhatsApp para respuesta inmediata."
    buttonText="Escribir por WhatsApp"
    buttonLink="https://wa.me/528112999069"
  />
</Layout>
