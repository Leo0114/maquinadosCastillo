---
import { Image } from "astro:assets";
import ScrollReveal from "@/components/shared/ScrollReveal.tsx";
import SectionHeader from "@/components/shared/SectionHeader.astro";
import { TbCut, TbBuildingFactory2, TbScan } from "react-icons/tb";

// Metal images for service highlights
import metalImg1 from "@/assets/images/metal/metal7.avif";
import metalImg2 from "@/assets/images/metal/metal20.avif";
import metalImg3 from "@/assets/images/metal/metal25.avif";

const services = [
  {
    title: "Maquinado CNC",
    description: "Fresado y torneado CNC de alta precisión. 5 centros verticales con hasta 50\" en X. Geometrías complejas y tolerancias estrechas.",
    image: metalImg1,
    Icon: TbCut,
    href: "/que-hacemos#maquinado-cnc",
    tag: "Precisión",
  },
  {
    title: "Herramentales",
    description: "Diseño y fabricación completa de moldes, matrices y troqueles. Desde prototipos hasta series cortas con acabado de primera.",
    image: metalImg2,
    Icon: TbBuildingFactory2,
    href: "/que-hacemos#herramentales",
    tag: "Ingeniería",
  },
  {
    title: "Ingeniería Inversa",
    description: "Escaneo 3D, digitalización y metrología. Reconstruimos piezas sin planos originales con exactitud milimétrica.",
    image: metalImg3,
    Icon: TbScan,
    href: "/que-hacemos#ingenieria",
    tag: "Innovación",
  },
];
---

<section class="section-py bg-canvas">
  <div class="container-custom">
    <ScrollReveal client:visible direction="up" className="mb-14">
      <SectionHeader
        eyebrow="Lo que hacemos"
        title="Soluciones integrales de maquinado"
        subtitle="Desde el diseño hasta la pieza terminada, somos tu socio estratégico en manufactura de precisión."
      />
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {services.map(({ title, description, image, Icon, href, tag }, i) => (
        <ScrollReveal client:visible direction="up" delay={i * 0.1} className="h-full">
          <article class="group relative bg-panel rounded-3xl overflow-hidden border border-line hover:border-primary/30 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary/10 h-full flex flex-col">
            {/* Image */}
            <div class="relative h-56 overflow-hidden">
              <Image
                src={image}
                alt={title}
                width={600}
                height={400}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-panel/80 to-transparent" />
              <span class="absolute top-4 left-4 px-3 py-1 rounded-full bg-primary/90 text-white text-xs font-semibold tracking-widest uppercase backdrop-blur-sm">
                {tag}
              </span>
            </div>

            {/* Content */}
            <div class="p-6 flex flex-col flex-1">
              <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center mb-4 group-hover:bg-primary group-hover:text-white transition-all duration-300">
                <Icon className="w-6 h-6 text-primary group-hover:text-white transition-colors duration-300" />
              </div>
              <h3 class="font-display font-bold text-xl text-ink mb-3 group-hover:text-primary transition-colors">
                {title}
              </h3>
              <p class="text-ink-muted text-sm leading-relaxed flex-1">{description}</p>
              <a
                href={href}
                class="mt-5 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-primary hover:gap-4 transition-all duration-300"
              >
                Ver más
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </article>
        </ScrollReveal>
      ))}
    </div>

    <!-- All services link -->
    <div class="text-center mt-12">
      <a
        href="/que-hacemos"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full border-2 border-primary text-primary text-sm font-bold uppercase tracking-widest hover:bg-primary hover:text-white transition-all duration-300 hover:-translate-y-0.5"
      >
        Ver todos los servicios
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
