---
import { Image } from "astro:assets";
import ScrollReveal from "@/components/shared/ScrollReveal.tsx";
import SectionHeader from "@/components/shared/SectionHeader.astro";

// Metal images for services
import img1 from "@/assets/images/metal/metal7.avif";
import img2 from "@/assets/images/metal/metal6.avif";
import img3 from "@/assets/images/metal/metal20.avif";
import img4 from "@/assets/images/metal/metal25.avif";
import img5 from "@/assets/images/metal/metal27.avif";
import img6 from "@/assets/images/metal/metal26.avif";

const services = [
  {
    id: "maquinado-cnc",
    icon: "⚙️",
    title: "Maquinado CNC",
    description: "Fresado y torneado CNC de alta precisión para piezas complejas con tolerancias estrechas.",
    image: img1,
    items: [
      "Fresado CNC Vertical — hasta 50\" en X",
      "Torneado CNC de alta precisión",
      "Geometrías 3D y superficies complejas",
      "Programación CAM avanzada",
    ],
  },
  {
    id: "maquinado-convencional",
    icon: "🔧",
    title: "Maquinado Convencional",
    description: "Fresado y torneado convencional para trabajos especializados que requieren mano de obra experta.",
    image: img2,
    items: [
      "Fresadoras de 9\"×36\" y 9\"×42\"",
      "Tornos de 16\"×58\" y 16\"×32\"",
      "Acabados superficiales finos",
      "Trabajos de ajuste y ensamble",
    ],
  },
  {
    id: "herramentales",
    icon: "🏗️",
    title: "Herramentales",
    description: "Diseño y fabricación completa de moldes, matrices y troqueles de alta calidad.",
    image: img3,
    items: [
      "Moldes de inyección y compresión",
      "Matrices de corte y embutido",
      "Troqueles progresivos",
      "Reparación de herramentales",
    ],
  },
  {
    id: "acabados",
    icon: "✨",
    title: "Acabados de Precisión",
    description: "Rectificado plano y cilíndrico para lograr los acabados superficiales más exactos.",
    image: img4,
    items: [
      "Rectificadora Cilíndrica ERWIN JUNKER",
      "Rectificadora Plana NORTON",
      "Erosionado por Hilo Accutex",
      "Acabados de espejo bajo requerimiento",
    ],
  },
  {
    id: "ingenieria",
    icon: "📐",
    title: "Ingeniería & Valor Agregado",
    description: "Diseño, escaneo 3D, ingeniería inversa y metrología para cerrar el ciclo productivo.",
    image: img5,
    items: [
      "Escaneo 3D y digitalización",
      "Ingeniería inversa sin planos",
      "Metrología dimensional",
      "Reportes dimensionales",
    ],
  },
  {
    id: "mantenimiento",
    icon: "🔩",
    title: "Mantenimiento & Pailería",
    description: "Mantenimiento industrial y trabajos de pailería para soporte a planta en operación.",
    image: img6,
    items: [
      "Mantenimiento de equipos industriales",
      "Trabajos de pailería y calderería",
      "Fabricación de piezas de repuesto",
      "Soporte en campo",
    ],
  },
];
---

<section class="section-py bg-canvas">
  <div class="container-custom">
    <ScrollReveal client:visible direction="up" className="mb-16">
      <SectionHeader
        eyebrow="Nuestros servicios"
        title="Todo lo que necesitas, en un solo lugar"
        subtitle="Capacidad completa de manufactura, desde el diseño hasta la pieza terminada con reporte dimensional."
      />
    </ScrollReveal>

    <div class="space-y-8">
      {services.map(({ id, icon, title, description, image, items }, i) => {
        const isEven = i % 2 === 0;
        return (
          <ScrollReveal client:visible direction="up" delay={0.05}>
            <article
              id={id}
              class="group grid grid-cols-1 md:grid-cols-2 gap-0 rounded-3xl overflow-hidden border border-line bg-panel hover:border-primary/30 hover:shadow-2xl hover:shadow-primary/5 transition-all duration-500 scroll-mt-24"
            >
              {/* Image */}
              <div class:list={[
                "relative overflow-hidden h-64 md:h-auto",
                !isEven && "md:order-last",
              ]}>
                <Image
                  src={image}
                  alt={title}
                  width={700}
                  height={500}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-r from-secondary/20 to-transparent" />
                <div class="absolute top-5 left-5 w-12 h-12 rounded-2xl bg-white/15 backdrop-blur-md flex items-center justify-center text-2xl shadow-lg">
                  {icon}
                </div>
              </div>

              {/* Content */}
              <div class="p-8 lg:p-10 flex flex-col justify-center">
                <h3 class="font-display font-bold text-2xl text-ink mb-3 group-hover:text-primary transition-colors">
                  {title}
                </h3>
                <p class="text-ink-muted leading-relaxed mb-6">{description}</p>
                <ul class="space-y-2.5">
                  {items.map((item) => (
                    <li class="flex items-center gap-3 text-sm text-ink-muted">
                      <span class="w-5 h-5 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                        <svg class="w-3 h-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                      </span>
                      {item}
                    </li>
                  ))}
                </ul>
                <a
                  href="/contacto"
                  class="mt-7 self-start inline-flex items-center gap-2 px-6 py-3 rounded-full bg-primary text-white text-xs font-bold uppercase tracking-widest hover:bg-primary-dark transition-all duration-300 hover:-translate-y-0.5 shadow-md shadow-primary/20"
                >
                  Solicitar cotización
                </a>
              </div>
            </article>
          </ScrollReveal>
        );
      })}
    </div>
  </div>
</section>
