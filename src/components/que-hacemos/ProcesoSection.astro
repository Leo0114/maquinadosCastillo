---
import ScrollReveal from "@/components/shared/ScrollReveal.tsx";
import SectionHeader from "@/components/shared/SectionHeader.astro";

const steps = [
  { number: "01", title: "Diseño & CAD", description: "Revisión de planos o escaneo 3D de la pieza. Generación del modelo 3D si se requiere ingeniería inversa." },
  { number: "02", title: "Programación CAM", description: "Generación de trayectorias de corte optimizadas. Simulación y validación virtual del proceso." },
  { number: "03", title: "Maquinado", description: "Ejecución en centros CNC o maquinaria convencional según el requerimiento de cada pieza." },
  { number: "04", title: "Acabados", description: "Rectificado, erosionado por hilo y acabados superficiales para cumplir especificaciones finales." },
  { number: "05", title: "Metrología", description: "Inspección dimensional completa con equipo 3D. Reporte de resultados y trazabilidad garantizada." },
  { number: "06", title: "Pieza Terminada", description: "Entrega con documentación completa, reporte dimensional y empaque adecuado para cada pieza." },
];
---

<section class="section-py bg-secondary overflow-hidden">
  <div class="container-custom">
    <ScrollReveal client:visible direction="up" className="mb-16">
      <SectionHeader
        eyebrow="Nuestro proceso"
        title="De la idea a la pieza terminada"
        subtitle="Un proceso integrado que garantiza calidad en cada etapa, desde la recepción del plano hasta la entrega con reporte dimensional."
        light
      />
    </ScrollReveal>

    <div class="relative">
      <!-- Connector line (desktop) -->
      <div class="hidden lg:block absolute top-8 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-white/15 to-transparent" />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-6">
        {steps.map(({ number, title, description }, i) => (
          <ScrollReveal client:visible direction="up" delay={i * 0.07}>
            <div class="relative flex flex-col items-center text-center">
              {/* Number bubble */}
              <div class="relative z-10 w-16 h-16 rounded-full bg-primary flex items-center justify-center shadow-xl shadow-primary/30 mb-4 shrink-0">
                <span class="font-display font-black text-white text-lg">{number}</span>
              </div>
              {/* Arrow (except last) */}
              {i < steps.length - 1 && (
                <div class="hidden lg:block absolute top-8 left-full -translate-y-1/2 w-full">
                  <svg class="w-6 h-6 text-white/20 -ml-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              )}
              <h3 class="font-display font-bold text-sm text-white mb-2">{title}</h3>
              <p class="text-white/55 text-xs leading-relaxed">{description}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </div>
</section>
