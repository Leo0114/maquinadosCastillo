---
import ScrollReveal from "@/components/shared/ScrollReveal.tsx";
---

<section class="section-py bg-canvas">
  <div class="container-custom">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
      
      <!-- Contact Info -->
      <ScrollReveal client:visible direction="right">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary mb-3">
            Información de contacto
          </p>
          <h2 class="font-display font-bold text-3xl lg:text-4xl text-ink mb-3">
            Hablemos de tu proyecto
          </h2>
          <p class="text-ink-muted leading-relaxed mb-8">
            Contáctenos por cualquiera de estos medios. Respondemos en menos de 24 horas para proyectos urgentes, en el mismo día.
          </p>

          <!-- Contact person -->
          <div class="flex items-center gap-4 p-5 rounded-2xl bg-panel border border-line mb-7">
            <div class="w-14 h-14 rounded-full bg-primary flex items-center justify-center text-white font-display font-bold text-xl shrink-0">
              GC
            </div>
            <div>
              <p class="font-display font-bold text-ink">Gonzalo Castillo</p>
              <p class="text-ink-muted text-sm">Director General</p>
            </div>
          </div>

          <!-- Contact items -->
          <div class="space-y-4">
            <!-- Phones -->
            {[
              { label: "Oficina", value: "81 8479 4210", href: "tel:+528184794210" },
              { label: "Móvil", value: "81 2723 5507", href: "tel:+528127235507" },
              { label: "Alternativo", value: "81 4468 7198", href: "tel:+528144687198" },
            ].map(({ label, value, href }) => (
              <a
                href={href}
                class="group flex items-center gap-4 p-4 rounded-2xl border border-line bg-panel hover:border-primary/40 hover:bg-primary/5 transition-all duration-300"
              >
                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0 group-hover:bg-primary group-hover:text-white transition-all duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-widest text-ink-muted">{label}</p>
                  <p class="font-semibold text-ink">{value}</p>
                </div>
              </a>
            ))}

            <!-- WhatsApp -->
            <a
              href="https://wa.me/528112999069"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 p-4 rounded-2xl border border-line bg-panel hover:border-green-500/40 hover:bg-green-50 dark:hover:bg-green-900/10 transition-all duration-300"
            >
              <div class="w-10 h-10 rounded-xl bg-green-100 dark:bg-green-900/30 flex items-center justify-center shrink-0 group-hover:bg-green-500 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-600 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-ink-muted">WhatsApp</p>
                <p class="font-semibold text-ink">81 1299 9069</p>
              </div>
            </a>

            <!-- Email -->
            <a
              href="mailto:gonzalo.castillo@mscastillo.com.mx"
              class="group flex items-center gap-4 p-4 rounded-2xl border border-line bg-panel hover:border-primary/40 hover:bg-primary/5 transition-all duration-300"
            >
              <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0 group-hover:bg-primary transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-widest text-ink-muted">Email</p>
                <p class="font-semibold text-ink text-sm truncate">gonzalo.castillo@mscastillo.com.mx</p>
              </div>
            </a>

            <!-- Location -->
            <div class="flex items-center gap-4 p-4 rounded-2xl border border-line bg-panel">
              <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-ink-muted">Ubicación</p>
                <p class="font-semibold text-ink">Escobedo, Nuevo León, México</p>
              </div>
            </div>
          </div>
        </div>
      </ScrollReveal>

      <!-- Contact Form -->
      <ScrollReveal client:visible direction="left" delay={0.1}>
        <div class="bg-panel rounded-3xl border border-line p-7 lg:p-9 shadow-xl shadow-ink/5">
          <h3 class="font-display font-bold text-2xl text-ink mb-2">Envíenos un mensaje</h3>
          <p class="text-ink-muted text-sm mb-7">
            Complete el formulario y nos pondremos en contacto en menos de 24 horas.
          </p>
          <form class="space-y-4" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold uppercase tracking-widest text-ink-muted mb-1.5" for="nombre">
                  Nombre *
                </label>
                <input
                  id="nombre"
                  name="nombre"
                  type="text"
                  placeholder="Su nombre completo"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-line bg-canvas text-ink placeholder-ink-muted/60 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200"
                />
              </div>
              <div>
                <label class="block text-xs font-semibold uppercase tracking-widest text-ink-muted mb-1.5" for="empresa">
                  Empresa
                </label>
                <input
                  id="empresa"
                  name="empresa"
                  type="text"
                  placeholder="Su empresa"
                  class="w-full px-4 py-3 rounded-xl border border-line bg-canvas text-ink placeholder-ink-muted/60 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200"
                />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold uppercase tracking-widest text-ink-muted mb-1.5" for="email">
                  Email *
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  placeholder="correo@empresa.com"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-line bg-canvas text-ink placeholder-ink-muted/60 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200"
                />
              </div>
              <div>
                <label class="block text-xs font-semibold uppercase tracking-widest text-ink-muted mb-1.5" for="telefono">
                  Teléfono
                </label>
                <input
                  id="telefono"
                  name="telefono"
                  type="tel"
                  placeholder="(81) 0000-0000"
                  class="w-full px-4 py-3 rounded-xl border border-line bg-canvas text-ink placeholder-ink-muted/60 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200"
                />
              </div>
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase tracking-widest text-ink-muted mb-1.5" for="servicio">
                Tipo de servicio
              </label>
              <select
                id="servicio"
                name="servicio"
                class="w-full px-4 py-3 rounded-xl border border-line bg-canvas text-ink text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200"
              >
                <option value="">Seleccionar...</option>
                <option>Maquinado CNC</option>
                <option>Herramentales (moldes/matrices)</option>
                <option>Acabados de precisión</option>
                <option>Ingeniería inversa / Escaneo 3D</option>
                <option>Mantenimiento industrial</option>
                <option>Otro</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase tracking-widest text-ink-muted mb-1.5" for="mensaje">
                Mensaje *
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows={5}
                placeholder="Describa su requerimiento, material, tolerancias, cantidad, fecha de entrega requerida..."
                required
                class="w-full px-4 py-3 rounded-xl border border-line bg-canvas text-ink placeholder-ink-muted/60 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200 resize-none"
              />
            </div>
            <button
              type="submit"
              class="w-full py-4 px-8 rounded-xl bg-primary text-white font-bold uppercase tracking-widest text-sm hover:bg-primary-dark transition-all duration-300 hover:-translate-y-0.5 shadow-xl shadow-primary/20 mt-2"
            >
              Enviar mensaje
            </button>
            <p class="text-center text-xs text-ink-muted">
              * Campos requeridos. También puede contactarnos por WhatsApp para respuesta inmediata.
            </p>
          </form>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
