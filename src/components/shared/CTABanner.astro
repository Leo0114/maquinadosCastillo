---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  buttonText?: string;
  buttonLink?: string;
  bgImage?: string; // CSS background image URL
  variant?: "dark" | "primary";
}

const {
  eyebrow,
  title,
  subtitle,
  buttonText,
  buttonLink = "/contacto",
  bgImage,
  variant = "dark",
} = Astro.props;

const bgClass = variant === "primary" ? "bg-primary" : "bg-secondary";
---

<section
  class:list={[
    "relative overflow-hidden py-20 lg:py-28",
    !bgImage && bgClass,
  ]}
  style={bgImage ? `background-image: url(${bgImage});` : undefined}
>
  <!-- Background overlay if image -->
  {bgImage && (
    <div class="absolute inset-0 bg-secondary/85 backdrop-blur-sm" />
  )}

  <!-- Decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-white/3 blur-3xl" />
    <div class="absolute -bottom-20 -left-20 w-96 h-96 rounded-full bg-primary/10 blur-3xl" />
    <!-- Grid pattern -->
    <div
      class="absolute inset-0 opacity-5"
      style="background-image: repeating-linear-gradient(0deg, white 0px, white 1px, transparent 1px, transparent 60px), repeating-linear-gradient(90deg, white 0px, white 1px, transparent 1px, transparent 60px);"
    />
  </div>

  <div class="container-custom relative z-10 text-center">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-white/50 mb-4">
        {eyebrow}
      </p>
    )}
    <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-white leading-tight max-w-3xl mx-auto">
      {title}
    </h2>
    {subtitle && (
      <p class="mt-5 text-base sm:text-lg text-white/65 max-w-2xl mx-auto leading-relaxed">
        {subtitle}
      </p>
    )}
    {buttonText && (
      <div class="mt-9 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={buttonLink}
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-white text-secondary text-sm font-bold uppercase tracking-widest hover:bg-white/90 transition-all duration-300 hover:-translate-y-0.5 shadow-xl"
        >
          {buttonText}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
