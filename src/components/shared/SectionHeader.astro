---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center" | "right";
  light?: boolean; // for use on dark backgrounds
  class?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  align = "center",
  light = false,
  class: className = "",
} = Astro.props;

const alignClass = {
  left: "text-left",
  center: "text-center mx-auto",
  right: "text-right ml-auto",
}[align];
---

<div class:list={["max-w-3xl", alignClass, className]}>
  {eyebrow && (
    <p
      class:list={[
        "text-xs font-semibold uppercase tracking-[0.2em] mb-3",
        light ? "text-white/50" : "text-primary",
      ]}
    >
      {eyebrow}
    </p>
  )}
  <h2
    class:list={[
      "font-display font-bold text-3xl sm:text-4xl lg:text-5xl leading-tight",
      light ? "text-white" : "text-ink",
    ]}
  >
    {title}
  </h2>
  {subtitle && (
    <p
      class:list={[
        "mt-4 text-base sm:text-lg leading-relaxed",
        light ? "text-white/65" : "text-ink-muted",
      ]}
    >
      {subtitle}
    </p>
  )}
</div>
