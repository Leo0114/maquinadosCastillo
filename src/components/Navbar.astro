---
import { Image } from "astro:assets";
import logo from "@/assets/logo.avif";
import ThemeToggle from "@/components/shared/ThemeToggle.astro";

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/que-hacemos", label: "Qué Hacemos" },
  { href: "/acerca-de", label: "Acerca de" },
  { href: "/contacto", label: "Contacto" },
];

const currentPath = Astro.url.pathname;
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  data-navbar
>
  <div class="container-custom flex h-18 items-center justify-between py-4">
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-3 group"
      aria-label="Maquinados Castillo"
    >
      <Image
        src={logo}
        alt="Maquinados Castillo"
        width={48}
        height={48}
        class="rounded-lg object-contain transition-transform duration-300 group-hover:scale-105"
      />
      <span
        class="hidden sm:block font-display font-bold text-sm leading-tight text-white drop-shadow-sm"
      >
        Maquinados<br />Castillo
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav
      class="hidden lg:flex items-center gap-1"
      aria-label="Navegación principal"
    >
      {
        navLinks.map(({ href, label }) => {
          const isActive =
            href === "/" ? currentPath === "/" : currentPath.startsWith(href);
          return (
            <a
              href={href}
              class:list={[
                "relative px-4 py-2 text-sm font-medium transition-colors duration-200 rounded-lg",
                "text-white/80 hover:text-white hover:bg-white/10",
                isActive && "text-white bg-white/15 font-semibold",
              ]}
              aria-current={isActive ? "page" : undefined}
            >
              {label}
              {isActive && (
                <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-primary" />
              )}
            </a>
          );
        })
      }
    </nav>

    <!-- Right side: ThemeToggle + CTA + Hamburger -->
    <div class="flex items-center gap-3">
      <!-- CTA desktop -->
      <!-- <a
        href="/contacto"
        class="hidden lg:inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-primary text-white text-xs font-semibold uppercase tracking-widest hover:bg-primary-dark transition-all duration-300 hover:-translate-y-0.5 shadow-lg shadow-primary/30"
      >
        Cotizar
      </a> -->

      <ThemeToggle />

      <!-- Hamburger -->
      <button
        id="nav-hamburger"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="lg:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-white/10 transition-colors"
      >
        <span
          class="hamburger-line block w-5 h-0.5 bg-white rounded-full transition-all duration-300"
        ></span>
        <span
          class="hamburger-line block w-5 h-0.5 bg-white rounded-full transition-all duration-300"
        ></span>
        <span
          class="hamburger-line block w-5 h-0.5 bg-white rounded-full transition-all duration-300"
        ></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden overflow-hidden"
    role="navigation"
    aria-label="Menú móvil"
  >
    <div class="container-custom pb-6 pt-2 border-t border-white/10">
      <nav class="flex flex-col gap-1">
        {
          navLinks.map(({ href, label }) => {
            const isActive =
              href === "/" ? currentPath === "/" : currentPath.startsWith(href);
            return (
              <a
                href={href}
                class:list={[
                  "px-4 py-3 rounded-xl text-sm font-medium transition-colors duration-200",
                  "text-white/80 hover:text-white hover:bg-white/10",
                  isActive && "text-white bg-white/15 font-semibold",
                ]}
              >
                {label}
              </a>
            );
          })
        }
        <a
          href="/contacto"
          class="mt-3 px-5 py-3 rounded-full bg-primary text-white text-xs font-semibold uppercase tracking-widest text-center hover:bg-primary-dark transition-colors"
        >
          Solicitar cotización
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const navbar = document.getElementById("navbar");
    const hamburger = document.getElementById("nav-hamburger");
    const mobileMenu = document.getElementById("mobile-menu");

    // Scroll behavior
    const onScroll = () => {
      if (!navbar) return;
      if (window.scrollY > 60) {
        navbar.classList.add(
          "bg-secondary/95",
          "backdrop-blur-md",
          "shadow-xl",
          "shadow-black/20",
        );
      } else {
        navbar.classList.remove(
          "bg-secondary/95",
          "backdrop-blur-md",
          "shadow-xl",
          "shadow-black/20",
        );
      }
    };

    window.removeEventListener("scroll", onScroll);
    window.addEventListener("scroll", onScroll);
    onScroll();

    // Hamburger toggle
    if (hamburger && mobileMenu) {
      hamburger.addEventListener("click", () => {
        const isOpen = mobileMenu.classList.toggle("hidden") === false;
        hamburger.setAttribute("aria-expanded", String(isOpen));
      });

      // Close on link click
      mobileMenu.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu.classList.add("hidden");
          hamburger.setAttribute("aria-expanded", "false");
        });
      });
    }
  });
</script>
