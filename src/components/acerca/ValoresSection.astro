---
import ScrollReveal from "@/components/shared/ScrollReveal.tsx";
import SectionHeader from "@/components/shared/SectionHeader.astro";

const values = [
  {
    icon: "🎯",
    title: "Precisión Absoluta",
    description: "Cada pieza cumple con las tolerancias más exigentes. No hay margen para errores en la industria de precisión.",
  },
  {
    icon: "⚡",
    title: "Respuesta Ágil",
    description: "Cuando la línea de producción no puede parar, respondemos. Nuestra capacidad de reacción rápida es uno de nuestros mayores activos.",
  },
  {
    icon: "🔬",
    title: "Tecnología Avanzada",
    description: "Metrología 3D, escaneo e ingeniería inversa integrados al proceso. Tecnología de punta al servicio de cada proyecto.",
  },
  {
    icon: "🤝",
    title: "Compromiso Total",
    description: "Trabajamos de la mano con cada cliente para entender sus necesidades y entregar soluciones que impulsen su productividad.",
  },
  {
    icon: "🏭",
    title: "Capacidad Integral",
    description: "Diseño + maquinado + ajuste + metrología en un solo lugar. Desde el plano hasta la pieza terminada.",
  },
  {
    icon: "📈",
    title: "Mejora Continua",
    description: "Sistema de gestión de calidad, capacitación constante y consultores empresariales certificados respaldan cada proceso.",
  },
];
---

<section class="section-py bg-panel">
  <div class="container-custom">
    <ScrollReveal client:visible direction="up" className="mb-14">
      <SectionHeader
        eyebrow="Nuestra filosofía"
        title="Valores que guían cada proyecto"
        subtitle="Los principios que nos han mantenido como proveedor confiable por más de 30 años en la industria."
      />
    </ScrollReveal>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {values.map(({ icon, title, description }, i) => (
        <ScrollReveal client:visible direction="up" delay={i * 0.08}>
          <div class="group p-6 rounded-3xl border border-line bg-canvas hover:bg-panel hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-500 hover:-translate-y-1">
            <div class="text-4xl mb-4">{icon}</div>
            <h3 class="font-display font-bold text-lg text-ink mb-2 group-hover:text-primary transition-colors">
              {title}
            </h3>
            <p class="text-ink-muted text-sm leading-relaxed">{description}</p>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
