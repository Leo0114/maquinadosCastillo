---
import ScrollReveal from "@/components/shared/ScrollReveal.tsx";
import SectionHeader from "@/components/shared/SectionHeader.astro";

const sectors = [
  {
    name: "Automotriz",
    years: "30",
    description: "Proveedor de primer nivel para la industria automotriz de Nuevo León y el norte de México.",
    icon: "🚗",
  },
  {
    name: "Electrodomésticos",
    years: "8",
    description: "Fabricación de moldes y piezas para marcas líderes mundiales de electrodomésticos.",
    icon: "🏠",
  },
  {
    name: "Metal-mecánico",
    years: "6",
    description: "Soporte a empresas del sector metalmecánico con piezas de alta precisión y herramentales.",
    icon: "⚙️",
  },
  {
    name: "Industria General",
    years: "2",
    description: "Soluciones para proyectos de ingeniería general que requieren maquinado de alta calidad.",
    icon: "🏭",
  },
  {
    name: "Internacional (EUA)",
    years: "2026",
    description: "Expansión como proveedor certificado para cliente en Roanoke, Virginia, USA a partir de 2026.",
    icon: "🌐",
    highlight: true,
  },
];
---

<section class="section-py bg-canvas">
  <div class="container-custom">
    <ScrollReveal client:visible direction="up" className="mb-14">
      <SectionHeader
        eyebrow="Sectores que atendemos"
        title="Líderes mundiales confían en nosotros"
        subtitle="Nuestros clientes pertenecen a los sectores industriales más exigentes del mundo."
      />
    </ScrollReveal>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-5">
      {sectors.map(({ name, years, description, icon, highlight }, i) => (
        <ScrollReveal client:visible direction="up" delay={i * 0.08}>
          <div
            class:list={[
              "relative p-6 rounded-3xl border text-center flex flex-col items-center transition-all duration-300 hover:-translate-y-1 hover:shadow-xl h-full",
              highlight
                ? "bg-primary text-white border-primary shadow-lg shadow-primary/20"
                : "bg-panel border-line hover:border-primary/30 hover:shadow-primary/10",
            ]}
          >
            <div class="text-4xl mb-3">{icon}</div>
            <p
              class:list={[
                "font-display font-black text-4xl mb-1",
                highlight ? "text-white" : "text-primary",
              ]}
            >
              {years === "2026" ? "★" : `${years}+`}
            </p>
            <p
              class:list={[
                "text-xs font-semibold uppercase tracking-widest mb-3",
                highlight ? "text-white/70" : "text-ink-muted",
              ]}
            >
              {years === "2026" ? "Desde 2026" : "Años proveedor"}
            </p>
            <h3
              class:list={[
                "font-display font-bold text-base mb-2",
                highlight ? "text-white" : "text-ink",
              ]}
            >
              {name}
            </h3>
            <p
              class:list={[
                "text-xs leading-relaxed",
                highlight ? "text-white/75" : "text-ink-muted",
              ]}
            >
              {description}
            </p>
            {highlight && (
              <span class="absolute top-4 right-4 px-2 py-0.5 rounded-full bg-white/20 text-white text-xs font-bold uppercase tracking-widest">
                Nuevo
              </span>
            )}
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
